# ─── Server ──────────────────────────────────────────────
PORT=3001

# ─── JWT ─────────────────────────────────────────────────
# Generate a long random string. Used to sign session tokens.
# Run: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=30d

# ─── Twilio Verify ───────────────────────────────────────
# Get these from https://console.twilio.com
# 1. Create a free Twilio account
# 2. Verify → Services → Create new service (name it "OtaExpress")
# 3. Copy the Service SID (starts with VAxxxxxx)
# 4. Buy a Twilio phone number (Phone Numbers → Buy a Number)
# 5. Inside the Verify Service, enable the SMS channel
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ─── OTP delivery channel ────────────────────────────────
# Which channel Twilio Verify uses to deliver the code:
#   sms      — default. Works on any Twilio account with a phone number.
#              No business verification needed.
#   whatsapp — requires a Meta-verified WhatsApp Sender attached to your
#              Verify Service. Business verification takes days to weeks.
#   call     — voice call that reads the code aloud.
#   email    — needs an email integration on the Verify Service.
OTP_CHANNEL=sms

# ─── Dev mode ────────────────────────────────────────────
# When Twilio credentials are blank, the server runs in "dev mode":
# it accepts the OTP code "123456" for any phone number and logs
# what it WOULD have sent. Set ALLOW_DEV_MODE=false to require Twilio.
ALLOW_DEV_MODE=true

# ─── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
